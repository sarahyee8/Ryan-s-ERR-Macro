    Dim keepCols As Variant
    Dim keepColNums() As Long
    Dim filteredHeader As Variant
    
    Dim r As Long
    Dim person As String, safeName As String
    Dim includeFlag As String
    Dim forecastSource As String
    Dim wsP As Worksheet
    Dim targetRow As Long
    Dim startNRow As Long
    Dim startClosedRow As Long
    Dim forecastSourceCol As Long
    
    On Error GoTo CleanFail
    
    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.Calculation = xlCalculationManual
    
    Set wb = ThisWorkbook
    Set wsSrc = wb.Worksheets("FinalOpps")
    
    Set dictSheets = CreateObject("Scripting.Dictionary")
    Set dictNextY = CreateObject("Scripting.Dictionary")
    Set dictNextN = CreateObject("Scripting.Dictionary")
    Set dictNextClosed = CreateObject("Scripting.Dictionary")
    Set dictNStarted = CreateObject("Scripting.Dictionary")
    Set dictClosedStarted = CreateObject("Scripting.Dictionary")
    
    dictSheets.CompareMode = vbTextCompare
    dictNextY.CompareMode = vbTextCompare
    dictNextN.CompareMode = vbTextCompare
    dictNextClosed.CompareMode = vbTextCompare
    dictNStarted.CompareMode = vbTextCompare
    dictClosedStarted.CompareMode = vbTextCompare
    
    ' Col Q = 17
    lastRow = wsSrc.Cells(wsSrc.Rows.Count, 17).End(xlUp).Row
    lastCol = wsSrc.Cells(1, wsSrc.Columns.Count).End(xlToLeft).Column
    
    If lastRow < 2 Then GoTo CleanExit
    
    dataArr = wsSrc.Range(wsSrc.Cells(2, 1), wsSrc.Cells(lastRow, lastCol)).Value
    
    forecastSourceCol = GetHeaderColumn(wsSrc, "Forecast Source")
    If forecastSourceCol = 0 Then
        Err.Raise vbObjectError + 1000, , "Could not find 'Forecast Source' column in FinalOpps."
    End If
    
    ' keep only the visible/output columns
    keepCols = Array("O", "BJ", "BK", "D", "G", "Q", "F", "E", "K", "I", "AC", "AD", "AA", "U", "W", "BU", "CJ", "CM", "CG", "CN")
    keepColNums = GetColumnNumbers(keepCols)
    filteredHeader = GetFilteredHeader(wsSrc, keepColNums)
    
    ' First pass: create owner sheets
    For r = 1 To UBound(dataArr, 1)
        person = Trim$(CStr(dataArr(r, 17)))   ' Column Q
        
        If Len(person) > 0 Then
            safeName = MakeSafeSheetName(person)
            
            If Not dictSheets.Exists(safeName) Then
                dictSheets.Add safeName, True
                
                Set wsP = GetOrCreateSheet(wb, safeName)
                wsP.Cells.Clear
                
                With wsP.Cells(1, 1)
                    .Value = "Changes Detected"
                    .Font.Bold = True
                    .Font.Size = 16
                End With
                
                wsP.Range(wsP.Cells(2, 1), wsP.Cells(2, UBound(keepColNums))).Value = filteredHeader
                
                dictNextY.Add safeName, 3
                dictNStarted.Add safeName, False
                dictClosedStarted.Add safeName, False
            End If
        End If
    Next r
    
    ' Second pass: distribute rows
    For r = 1 To UBound(dataArr, 1)
        person = Trim$(CStr(dataArr(r, 17)))   ' Column Q
        If Len(person) = 0 Then GoTo NextR
        
        safeName = MakeSafeSheetName(person)
        Set wsP = wb.Worksheets(safeName)
        
        includeFlag = UCase$(Trim$(CStr(dataArr(r, 88))))   ' CJ
        forecastSource = UCase$(Trim$(CStr(dataArr(r, forecastSourceCol))))
        
        If forecastSource = "PREVIOUS" Then
            
            If Not CBool(dictClosedStarted(safeName)) Then
                startClosedRow = CLng(dictNextY(safeName)) + 1
                
                With wsP.Cells(startClosedRow + 1, 1)
                    .Value = "Closed Opps Detected"
                    .Font.Bold = True
                    .Font.Size = 16
                End With
                
                wsP.Range(wsP.Cells(startClosedRow + 2, 1), wsP.Cells(startClosedRow + 2, UBound(keepColNums))).Value = filteredHeader
                
                dictNextClosed.Add safeName, startClosedRow + 3
                dictClosedStarted(safeName) = True
            End If
            
            targetRow = CLng(dictNextClosed(safeName))
            wsP.Range(wsP.Cells(targetRow, 1), wsP.Cells(targetRow, UBound(keepColNums))).Value = _
                GetFilteredRowAs2D(dataArr, r, keepColNums)
            dictNextClosed(safeName) = targetRow + 1
            
        ElseIf includeFlag = "Y" Then
            
            targetRow = CLng(dictNextY(safeName))
            wsP.Range(wsP.Cells(targetRow, 1), wsP.Cells(targetRow, UBound(keepColNums))).Value = _
                GetFilteredRowAs2D(dataArr, r, keepColNums)
            dictNextY(safeName) = targetRow + 1
            
        ElseIf includeFlag = "N" Then
            
            If Not CBool(dictNStarted(safeName)) Then
                If CBool(dictClosedStarted(safeName)) Then
                    startNRow = CLng(dictNextClosed(safeName)) + 1
                Else
                    startNRow = CLng(dictNextY(safeName)) + 1
                End If
                
                With wsP.Cells(startNRow + 1, 1)
                    .Value = "No Changes Detected"
                    .Font.Bold = True
                    .Font.Size = 16
                End With
                
                wsP.Range(wsP.Cells(startNRow + 2, 1), wsP.Cells(startNRow + 2, UBound(keepColNums))).Value = filteredHeader
                
                dictNextN.Add safeName, startNRow + 3
                dictNStarted(safeName) = True
            End If
            
            targetRow = CLng(dictNextN(safeName))
            wsP.Range(wsP.Cells(targetRow, 1), wsP.Cells(targetRow, UBound(keepColNums))).Value = _
                GetFilteredRowAs2D(dataArr, r, keepColNums)
            dictNextN(safeName) = targetRow + 1
        End If
        
NextR:
    Next r
    
    FormatDistributedSheetsSimple dictSheets
    GoTo CleanExit

CleanExit:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Application.Calculation = xlCalculationAutomatic
    Exit Sub

CleanFail:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Application.Calculation = xlCalculationAutomatic
    MsgBox "Distribution failed: " & Err.Description, vbExclamation
End Sub

Private Sub FormatDistributedSheetsSimple(ByVal dictSheets As Object)
    Dim key As Variant
    Dim ws As Worksheet
    Dim lastRow As Long, lastCol As Long
    Dim lo As ListObject
    
    For Each key In dictSheets.Keys
        Set ws = ThisWorkbook.Worksheets(CStr(key))
        
        On Error Resume Next
        For Each lo In ws.ListObjects
            lo.Delete
        Next lo
        On Error GoTo 0
        
        lastRow = LastUsedRow(ws)
        lastCol = ws.Cells(2, ws.Columns.Count).End(xlToLeft).Column
        
        If lastRow > 0 And lastCol > 0 Then
            ApplySectionTable ws, 2, "tblChanges_" & SafeTableName(ws.Name)
            
            Dim closedTitleRow As Long, noChangeTitleRow As Long
            closedTitleRow = FindRowByTextInColA(ws, "Closed Opps Detected")
            noChangeTitleRow = FindRowByTextInColA(ws, "No Changes Detected")
            
            If closedTitleRow > 0 Then
                ApplySectionTable ws, closedTitleRow + 1, "tblClosedOpps_" & SafeTableName(ws.Name)
            End If
            
            If noChangeTitleRow > 0 Then
                ApplySectionTable ws, noChangeTitleRow + 1, "tblNoChanges_" & SafeTableName(ws.Name)
            End If
        End If
        
        ws.Columns.AutoFit
    Next key
End Sub

Private Sub ApplySectionTable(ByVal ws As Worksheet, ByVal headerRow As Long, ByVal tableName As String)
    Dim dataLastRow As Long
    Dim nextSectionRow As Long
    Dim lastCol As Long
    Dim rngTable As Range
    Dim lo As ListObject
    
    lastCol = ws.Cells(headerRow, ws.Columns.Count).End(xlToLeft).Column
    If lastCol = 0 Then Exit Sub
    
    nextSectionRow = FindNextSectionTitleRow(ws, headerRow + 1)
    
    If nextSectionRow > 0 Then
        dataLastRow = nextSectionRow - 2
    Else
        dataLastRow = LastUsedRow(ws)
    End If
    
    If dataLastRow < headerRow Then Exit Sub
    
    Set rngTable = ws.Range(ws.Cells(headerRow, 1), ws.Cells(dataLastRow, lastCol))
    
    ApplyBorders rngTable
    
    If rngTable.Rows.Count >= 1 And rngTable.Columns.Count >= 1 Then
        Set lo = ws.ListObjects.Add(xlSrcRange, rngTable, , xlYes)
        On Error Resume Next
        lo.Name = tableName
        On Error GoTo 0
        
        With lo
            .TableStyle = "TableStyleMedium2"
            .ShowTableStyleRowStripes = True
            .ShowTableStyleColumnStripes = False
        End With
    End If
End Sub

Private Function FindNextSectionTitleRow(ByVal ws As Worksheet, ByVal startRow As Long) As Long
    Dim r As Long
    Dim lastRow As Long
    Dim txt As String
    
    lastRow = LastUsedRow(ws)
    
    For r = startRow To lastRow
        txt = Trim$(CStr(ws.Cells(r, 1).Value))
        If txt = "Closed Opps Detected" Or txt = "No Changes Detected" Then
            FindNextSectionTitleRow = r
            Exit Function
        End If
    Next r
    
    FindNextSectionTitleRow = 0
End Function

Private Function GetColumnNumbers(ByVal keepCols As Variant) As Long()
    Dim arr() As Long
    Dim i As Long
    
    ReDim arr(1 To UBound(keepCols) - LBound(keepCols) + 1)
    
    For i = LBound(keepCols) To UBound(keepCols)
        arr(i - LBound(keepCols) + 1) = ColumnLetterToNumber(CStr(keepCols(i)))
    Next i
    
    GetColumnNumbers = arr
End Function

Private Function GetFilteredHeader(ByVal ws As Worksheet, ByRef keepColNums() As Long) As Variant
    Dim outArr() As Variant
    Dim i As Long
    
    ReDim outArr(1 To 1, 1 To UBound(keepColNums))
    
    For i = 1 To UBound(keepColNums)
        outArr(1, i) = ws.Cells(1, keepColNums(i)).Value
    Next i
    
    GetFilteredHeader = outArr
End Function

Private Function GetFilteredRowAs2D(ByRef dataArr As Variant, ByVal r As Long, ByRef keepColNums() As Long) As Variant
    Dim outArr() As Variant
    Dim i As Long
    
    ReDim outArr(1 To 1, 1 To UBound(keepColNums))
    
    For i = 1 To UBound(keepColNums)
        outArr(1, i) = dataArr(r, keepColNums(i))
    Next i
    
    GetFilteredRowAs2D = outArr
End Function

Private Function GetOrCreateSheet(ByVal wb As Workbook, ByVal sheetName As String) As Worksheet
    On Error Resume Next
    Set GetOrCreateSheet = wb.Worksheets(sheetName)
    On Error GoTo 0
    
    If GetOrCreateSheet Is Nothing Then
        Set GetOrCreateSheet = wb.Worksheets.Add(After:=wb.Worksheets(wb.Worksheets.Count))
        GetOrCreateSheet.Name = sheetName
    End If
End Function

Private Function MakeSafeSheetName(ByVal rawName As String) As String
    Dim badChars As Variant, ch As Variant
    Dim s As String
    
    s = Trim$(rawName)
    badChars = Array("\", "/", "?", "*", "[", "]", ":", "'")
    
    For Each ch In badChars
        s = Replace$(s, CStr(ch), " ")
    Next ch
    
    Do While InStr(s, "  ") > 0
        s = Replace$(s, "  ", " ")
    Loop
    
    s = Trim$(s)
    If Len(s) = 0 Then s = "Unknown"
    If Len(s) > 31 Then s = Left$(s, 31)
    If Right$(s, 1) = "'" Then s = Left$(s, Len(s) - 1)
    
    MakeSafeSheetName = s
End Function

Private Function GetHeaderColumn(ByVal ws As Worksheet, ByVal headerName As String) As Long
    Dim lastCol As Long
    Dim c As Long
    
    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
    
    For c = 1 To lastCol
        If Trim$(CStr(ws.Cells(1, c).Value)) = headerName Then
            GetHeaderColumn = c
            Exit Function
        End If
    Next c
    
    GetHeaderColumn = 0
End Function

Private Sub ApplyBorders(ByVal rng As Range)
    With rng.Borders
        .LineStyle = xlContinuous
        .Weight = xlThin
    End With
End Sub

Private Function FindRowByTextInColA(ByVal ws As Worksheet, ByVal findText As String) As Long
    Dim lastRow As Long
    Dim r As Long
    
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    
    For r = 1 To lastRow
        If Trim$(CStr(ws.Cells(r, 1).Value)) = findText Then
            FindRowByTextInColA = r
            Exit Function
        End If
    Next r
    
    FindRowByTextInColA = 0
End Function

Private Function LastUsedRow(ByVal ws As Worksheet) As Long
    Dim lastCell As Range
    
    On Error Resume Next
    Set lastCell = ws.Cells.Find(What:="*", After:=ws.Cells(1, 1), LookIn:=xlFormulas, _
                                 LookAt:=xlPart, SearchOrder:=xlByRows, SearchDirection:=xlPrevious)
    On Error GoTo 0
    
    If lastCell Is Nothing Then
        LastUsedRow = 0
    Else
        LastUsedRow = lastCell.Row
    End If
End Function

Private Function ColumnLetterToNumber(ByVal colLetter As String) As Long
    ColumnLetterToNumber = Range(UCase$(colLetter) & "1").Column
End Function

Private Function SafeTableName(ByVal s As String) As String
    Dim i As Long
    Dim ch As String
    Dim outStr As String
    
    For i = 1 To Len(s)
        ch = Mid$(s, i, 1)
        If ch Like "[A-Za-z0-9_]" Then
            outStr = outStr & ch
        Else
            outStr = outStr & "_"
        End If
    Next i
    
    If Len(outStr) = 0 Then outStr = "Sheet"
    SafeTableName = outStr
End Function
