                logicArr(outRow, RenewDateFlagCol) = "Y"
            Else
                logicArr(outRow, RenewDateFlagCol) = "N"
            End If
            
            If dataCurr(i, 73) = "Y" Then
                If Len(oppID) > 0 And dictPrev.Exists(oppID) Then
                    logicArr(outRow, ChangeTerrCol) = IIf(Trim$(CStr(dataCurr(i, 7))) = Trim$(CStr(dataPrev(dictPrev(oppID), 7))), "N", "Y")
