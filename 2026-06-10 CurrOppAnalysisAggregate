Private Sub BuildDistributionSummary(ByVal dictSheets As Object)
    Dim wsSum As Worksheet
    Dim key As Variant
    Dim wsP As Worksheet
    
    On Error Resume Next
    Set wsSum = ThisWorkbook.Worksheets("Dashboard")
    On Error GoTo 0
    
    If wsSum Is Nothing Then
        MsgBox "Dashboard sheet was not found. Please create a sheet named Dashboard and run again.", vbExclamation
        Exit Sub
    End If
    
    wsSum.Range("A1:H9").Clear
    
    AddTopAnalyticsLayout wsSum
    
    For Each key In dictSheets.Keys
        Set wsP = ThisWorkbook.Worksheets(CStr(key))
        
        wsSum.Range("B2").Value = Val(wsSum.Range("B2").Value) + Val(wsP.Range("B2").Value)
        wsSum.Range("B3").Value = Val(wsSum.Range("B3").Value) + Val(wsP.Range("B3").Value)
        wsSum.Range("B4").Value = Val(wsSum.Range("B4").Value) + Val(wsP.Range("B4").Value)
        wsSum.Range("B5").Value = Val(wsSum.Range("B5").Value) + Val(wsP.Range("B5").Value)
        wsSum.Range("B6").Value = Val(wsSum.Range("B6").Value) + Val(wsP.Range("B6").Value)
        wsSum.Range("B7").Value = Val(wsSum.Range("B7").Value) + Val(wsP.Range("B7").Value)
        wsSum.Range("B8").Value = Val(wsSum.Range("B8").Value) + Val(wsP.Range("B8").Value)
        
        wsSum.Range("D2").Value = Val(wsSum.Range("D2").Value) + Val(wsP.Range("D2").Value)
        wsSum.Range("D3").Value = Val(wsSum.Range("D3").Value) + Val(wsP.Range("D3").Value)
        wsSum.Range("D4").Value = Val(wsSum.Range("D4").Value) + Val(wsP.Range("D4").Value)
        
        wsSum.Range("F2").Value = Val(wsSum.Range("F2").Value) + Val(wsP.Range("F2").Value)
        wsSum.Range("F3").Value = Val(wsSum.Range("F3").Value) + Val(wsP.Range("F3").Value)
        wsSum.Range("F4").Value = Val(wsSum.Range("F4").Value) + Val(wsP.Range("F4").Value)
        wsSum.Range("F5").Value = Val(wsSum.Range("F5").Value) + Val(wsP.Range("F5").Value)
    Next key
    
    With wsSum.Range("H1")
        .Formula = "=SUM(F2:F5)"
        .HorizontalAlignment = xlLeft
        .Font.Bold = True
    End With
    
    Application.Calculate

    wsSum.Columns("A:H").AutoFit
    
    wsSum.Columns("B").ColumnWidth = wsSum.Columns("B").ColumnWidth + 2
    wsSum.Columns("D").ColumnWidth = wsSum.Columns("D").ColumnWidth + 2
    wsSum.Columns("F").ColumnWidth = wsSum.Columns("F").ColumnWidth + 2
    wsSum.Columns("H").ColumnWidth = wsSum.Columns("H").ColumnWidth + 2
End Sub
