            logicArr(outRow, 64) = dataPrev(i, 55)   ' BL <- BC
            logicArr(outRow, 73) = dataPrev(i, 56)   ' BU <- BD
            logicArr(outRow, 74) = dataPrev(i, 57)   ' BV <- BE
            logicArr(outRow, 79) = dataPrev(i, 58)   ' CA <- BF
            logicArr(outRow, 80) = dataPrev(i, 59)   ' CB <- BG
            logicArr(outRow, 81) = dataPrev(i, 60)   ' CC <- BH
            logicArr(outRow, 82) = dataPrev(i, 61)   ' CD <- BI
