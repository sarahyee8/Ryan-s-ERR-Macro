End Sub

Private Function IsPTGDatePastAnniversary(ByVal renewalAnniversaryDate As Variant, ByVal ptgRenewalExpectedDate As Variant) As Boolean
    If Not IsDate(renewalAnniversaryDate) Then
        IsPTGDatePastAnniversary = False
        Exit Function
    End If
    
    If Not IsDate(ptgRenewalExpectedDate) Then
        IsPTGDatePastAnniversary = False
        Exit Function
    End If
    
    IsPTGDatePastAnniversary = (DateValue(CDate(ptgRenewalExpectedDate)) > DateValue(CDate(renewalAnniversaryDate)))
End Function

Private Function FormatDateForDetails(ByVal v As Variant) As String
    If IsDate(v) Then
        FormatDateForDetails = Format$(CDate(v), "yyyy-mm-dd")
    Else
        FormatDateForDetails = CStr(v)
    End If
End Function









