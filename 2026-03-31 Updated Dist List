                    startNRow = CLng(dictNextY(safeName)) + 1
                End If
                
                With wsP.Cells(startNRow, 1)
                    .Value = "No Changes Detected"
                    .Font.Bold = True
                    .Font.Size = 16
                End With
                
                wsP.Range(wsP.Cells(startNRow + 1, 1), wsP.Cells(startNRow + 1, lastCol)).Value = headerArr
                
                dictNextN.Add safeName, startNRow + 2
                dictNStarted(safeName) = True
            End If
            
            targetRow = CLng(dictNextN(safeName))
            wsP.Range(wsP.Cells(targetRow, 1), wsP.Cells(targetRow, lastCol)).Value = _
                GetRowAs2D(dataArr, r, lastCol)
            dictNextN(safeName) = targetRow + 1
        End If
        
NextRN:
    Next r
    
    Call CleanDistributedSheets(dictSheets)
    GoTo CleanExit

CleanExit:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Application.Calculation = xlCalculationAutomatic
    Exit Sub

CleanFail:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Application.Calculation = xlCalculationAutomatic
    MsgBox "Distribution failed: " & Err.Description, vbExclamation
End Sub

Private Function GetOrCreateSheet(ByVal wb As Workbook, ByVal sheetName As String) As Worksheet
    On Error Resume Next
    Set GetOrCreateSheet = wb.Worksheets(sheetName)
    On Error GoTo 0
    
    If GetOrCreateSheet Is Nothing Then
        Set GetOrCreateSheet = wb.Worksheets.Add(After:=wb.Worksheets(wb.Worksheets.Count))
        GetOrCreateSheet.Name = sheetName
    End If
End Function

Private Function MakeSafeSheetName(ByVal rawName As String) As String
    Dim badChars As Variant, ch As Variant
    Dim s As String
    
    s = Trim$(rawName)
    badChars = Array("\", "/", "?", "*", "[", "]", ":", "'")
    
    For Each ch In badChars
        s = Replace$(s, CStr(ch), " ")
    Next ch
    
    Do While InStr(s, "  ") > 0
        s = Replace$(s, "  ", " ")
    Loop
    
    s = Trim$(s)
    If Len(s) = 0 Then s = "Unknown"
    If Len(s) > 31 Then s = Left$(s, 31)
    If Right$(s, 1) = "'" Then s = Left$(s, Len(s) - 1)
    
    MakeSafeSheetName = s
End Function

Private Function GetRowAs2D(ByRef dataArr As Variant, ByVal r As Long, ByVal lastCol As Long) As Variant
    Dim outArr() As Variant
    Dim c As Long
    
    ReDim outArr(1 To 1, 1 To lastCol)
    For c = 1 To lastCol
        outArr(1, c) = dataArr(r, c)
    Next c
    
    GetRowAs2D = outArr
End Function
