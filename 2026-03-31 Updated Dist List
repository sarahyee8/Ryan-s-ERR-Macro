Option Explicit

Public Sub DistributeFinalOpps_ByCJ()

    Dim wb As Workbook
    Dim wsSrc As Worksheet
    Dim lastRow As Long, lastCol As Long
    Dim dataArr As Variant, headerArr As Variant
    
    Dim dictSheets As Object
    Dim dictNextY As Object, dictNextN As Object, dictNextClosed As Object
    Dim dictNStarted As Object, dictClosedStarted As Object
    
    Dim r As Long
    Dim person As String, safeName As String
    Dim includeFlag As String, forecastSource As String
    Dim wsP As Worksheet
    Dim targetRow As Long
    Dim startNRow As Long, startClosedRow As Long
    
    Set wb = ThisWorkbook
    Set wsSrc = wb.Worksheets("FinalOpps")
    
    Set dictSheets = CreateObject("Scripting.Dictionary")
    Set dictNextY = CreateObject("Scripting.Dictionary")
    Set dictNextN = CreateObject("Scripting.Dictionary")
    Set dictNextClosed = CreateObject("Scripting.Dictionary")
    Set dictNStarted = CreateObject("Scripting.Dictionary")
    Set dictClosedStarted = CreateObject("Scripting.Dictionary")
    
    lastRow = wsSrc.Cells(wsSrc.Rows.Count, 17).End(xlUp).Row
    lastCol = wsSrc.Cells(1, wsSrc.Columns.Count).End(xlToLeft).Column
    
    If lastRow < 2 Then Exit Sub
    
    headerArr = wsSrc.Range(wsSrc.Cells(1, 1), wsSrc.Cells(1, lastCol)).Value
    dataArr = wsSrc.Range(wsSrc.Cells(2, 1), wsSrc.Cells(lastRow, lastCol)).Value
    
    ' --- Create sheets ---
    For r = 1 To UBound(dataArr, 1)
        person = Trim$(CStr(dataArr(r, 17)))
        If Len(person) > 0 Then
            
            safeName = MakeSafeSheetName(person)
            
            If Not dictSheets.Exists(safeName) Then
                
                dictSheets.Add safeName, True
                
                Set wsP = GetOrCreateSheet(wb, safeName)
                wsP.Cells.Clear
                
                wsP.Cells(1, 1).Value = "Changes Detected"
                wsP.Cells(1, 1).Font.Bold = True
                
                wsP.Range(wsP.Cells(2, 1), wsP.Cells(2, lastCol)).Value = headerArr
                
                dictNextY.Add safeName, 3
                dictNStarted.Add safeName, False
                dictClosedStarted.Add safeName, False
                
            End If
        End If
    Next r
    
    ' --- Distribute rows ---
    For r = 1 To UBound(dataArr, 1)
        
        person = Trim$(CStr(dataArr(r, 17)))
        If Len(person) = 0 Then GoTo NextR
        
        safeName = MakeSafeSheetName(person)
        Set wsP = wb.Worksheets(safeName)
        
        includeFlag = UCase$(Trim$(CStr(dataArr(r, 88))))     ' CJ
        forecastSource = UCase$(Trim$(CStr(dataArr(r, 92))))  ' CN
        
        ' ===== CLOSED OPPORTUNITIES =====
        If forecastSource = "PREVIOUS" Then
            
            If Not dictClosedStarted(safeName) Then
                
                If dictNStarted(safeName) Then
                    startClosedRow = dictNextN(safeName) + 1
                Else
                    startClosedRow = dictNextY(safeName) + 1
                End If
                
                wsP.Cells(startClosedRow, 1).Value = "Closed Opportunities"
                wsP.Cells(startClosedRow, 1).Font.Bold = True
                
                wsP.Range(wsP.Cells(startClosedRow + 1, 1), wsP.Cells(startClosedRow + 1, lastCol)).Value = headerArr
                
                dictNextClosed.Add safeName, startClosedRow + 2
                dictClosedStarted(safeName) = True
            End If
            
            targetRow = dictNextClosed(safeName)
            wsP.Range(wsP.Cells(targetRow, 1), wsP.Cells(targetRow, lastCol)).Value = _
                GetRowAs2D(dataArr, r, lastCol)
            dictNextClosed(safeName) = targetRow + 1
            
        ' ===== CHANGES DETECTED =====
        ElseIf includeFlag = "Y" Then
            
            targetRow = dictNextY(safeName)
            wsP.Range(wsP.Cells(targetRow, 1), wsP.Cells(targetRow, lastCol)).Value = _
                GetRowAs2D(dataArr, r, lastCol)
            dictNextY(safeName) = targetRow + 1
            
        ' ===== NO CHANGES =====
        ElseIf includeFlag = "N" Then
            
            If Not dictNStarted(safeName) Then
                
                startNRow = dictNextY(safeName) + 1
                
                wsP.Cells(startNRow, 1).Value = "No Changes Detected"
                wsP.Cells(startNRow, 1).Font.Bold = True
                
                wsP.Range(wsP.Cells(startNRow + 1, 1), wsP.Cells(startNRow + 1, lastCol)).Value = headerArr
                
                dictNextN.Add safeName, startNRow + 2
                dictNStarted(safeName) = True
            End If
            
            targetRow = dictNextN(safeName)
            wsP.Range(wsP.Cells(targetRow, 1), wsP.Cells(targetRow, lastCol)).Value = _
                GetRowAs2D(dataArr, r, lastCol)
            dictNextN(safeName) = targetRow + 1
            
        End If
        
NextR:
    Next r
    
    Call CleanDistributedSheets(dictSheets)

End Sub










